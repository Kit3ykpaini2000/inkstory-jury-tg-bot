# ── Telegram ──────────────────────────────────────────────────────────────────
# Токен бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ── Туннель ───────────────────────────────────────────────────────────────────
# Туннель для публичного доступа к Mini App
# cloudflare — cloudflared (trycloudflare.com), не требует регистрации
# xtunnel    — xtunnel http
TUNNEL_PROVIDER=xtunnel

# ── Парсер ────────────────────────────────────────────────────────────────────
# Интервал автозапуска парсера в минутах
PARSER_INTERVAL=30
# Постов на страницу при обходе API
PAGE_SIZE=20
# Пауза между запросами при сборе ссылок (секунды)
PAGE_PAUSE_LINKS=1.0
# Пауза между запросами при парсинге постов (секунды)
PAGE_PAUSE_POSTS=1.5

# ── Очередь ───────────────────────────────────────────────────────────────────
# Режим распределения постов:
#   balanced    — по наименьшей сумме (проверено + отклонено + в очереди)
#   open        — общая очередь, первый пришёл — первый взял
QUEUE_MODE=balanced
# Через сколько минут незавершённый пост возвращается в очередь
EXPIRE_MINUTES=30
# Как часто проверять просроченные посты (минуты)
EXPIRE_CHECK_INTERVAL=5

# ── Расписание ────────────────────────────────────────────────────────────────
# Время финального парсинга (по Москве)
FINAL_PARSER_HOUR=23
FINAL_PARSER_MINUTE=55
# Время смены дня (по Москве)
NEW_DAY_HOUR=0
NEW_DAY_MINUTE=1

# ── Проверка жюри ─────────────────────────────────────────────────────────────
# Максимальное допустимое количество слов при вводе
MAX_WORDS=100000
# Максимальное допустимое количество ошибок при вводе
MAX_ERRORS=10000

# ── GitHub Models AI (необязательно) ─────────────────────────────────────────
# GitHub Personal Access Token (получить на github.com/settings/tokens)
# Права не нужны — просто создай токен без галочек
GITHUB_TOKEN=your_github_token_here
# Модель (gpt-4o-mini рекомендуется)
GITHUB_MODEL=gpt-4o-mini
# Максимум символов на один запрос к AI
AI_CHUNK_SIZE=3000
